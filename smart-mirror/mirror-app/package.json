    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-simple-keyboard": "^3.8.183",
    "react-tsparticles": "^2.12.0",
    "tsparticles-slim": "^2.12.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
