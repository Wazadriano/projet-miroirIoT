# Smart Mirror - local environment configuration
# Copy this file to .env (same directory) and fill in the real values.
# .env is gitignored and MUST NOT be committed.
#
# SECURITY: the previous CRM token was leaked in git history and has been
# revoked. Generate a NEW token on the CRM (Laravel Sanctum) and put it here.

CRM_BASE_URL=https://api-kbeauty.a3n.fr/api
CRM_TOKEN=replace-with-rotated-crm-token

# PostgreSQL (lu par docker-compose.yml). En production, definir une vraie valeur
# ici dans .env (non commite) ; le defaut dev "smartmirror_dev" reste utilise sinon.
POSTGRES_PASSWORD=smartmirror_dev

# Cle maitre de chiffrement applicatif (AES-256-GCM, 32 octets en base64) utilisee
# par le device. En production sur le Pi : fournir via systemd-creds (recommande)
# ou MASTER_KEY_FILE plutot que par cette variable. Generation :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SMART_MIRROR_MASTER_KEY=
