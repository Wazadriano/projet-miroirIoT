# ============================================================
# KBeauty Mirror CRM — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env en Git
# ============================================================

# Application
APP_NAME="KBeauty Mirror CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Base de données PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kbeauty_crm
DB_USERNAME=kbeauty
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Queue
QUEUE_CONNECTION=redis

# Laravel Reverb (WebSocket)
REVERB_APP_ID=kbeauty-mirror-crm
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Storage (local en dev, S3-compatible en prod)
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=kbeauty-mirror-crm
# AWS_ENDPOINT=

# Mail (pour notifications admin)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@kbeauty-mirror.com
MAIL_FROM_NAME="${APP_NAME}"

# CORS — domaines autorisés (séparés par virgule en prod)
# Géré dans config/cors.php — FRONTEND_URL est utilisé automatiquement

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080

# Integrations
SHOPIFY_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
N8N_TOKEN=
N8N_WEBHOOK_SEANCE_FIN=
NOCODEUR_WEBHOOK_URL=
GITHUB_TOKEN=
MIRROR_SHARED_SECRET=
IA_MODEL=gpt-4o-mini

# Development only
TEST_CLIENT_EMAIL=admin@kbeauty.fr
VITE_REVERB_SCHEME=http
